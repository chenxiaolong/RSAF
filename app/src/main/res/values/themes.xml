<resources>
    <style name="Theme.RSAF" parent="Theme.Material3Expressive.DynamicColors.DayNight.NoActionBar">
        <!--
            This is the background in Android's splash screen and also the region outside the
            activity when performing a predictive back gesture from one activity to another within
            the same app.
            This must be set statically. Keep this in sync with PreferenceDefaults.containerColor.
        -->
        <item name="android:colorBackground">?attr/colorSurfaceContainer</item>

        <!--
            This prevents an ugly bar from showing up in the recents screen when another app is
            open and app lock is enabled.
        -->
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
</resources>
