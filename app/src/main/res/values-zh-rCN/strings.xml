    <!-- Main preferences -->
    <string name="pref_inhibit_battery_opt_name">禁用电池优化</string>
    <string name="pref_inhibit_battery_opt_desc">需要在后台上传文件。</string>
    <string name="pref_missing_notifications_name">缺少通知权限</string>
    <string name="pref_missing_notifications_desc">需要在后台上传文件时显示通知。</string>
    <string name="pref_add_remote_name">添加远程存储</string>
    <string name="pref_add_remote_desc">添加新的 rclone 远程存储配置。</string>
    <string name="pref_import_configuration_name">导入配置</string>
    <string name="pref_import_configuration_desc">导入现有的 rclone 配置文件。</string>
    <string name="pref_export_configuration_name">导出配置</string>
    <string name="pref_export_configuration_desc">将当前 rclone 配置导出到文件。</string>
    <string name="pref_add_file_extension_name">添加文件扩展名</string>
    <string name="pref_add_file_extension_desc">创建新文件时，自动添加与文件类型对应的文件扩展名。</string>
    <string name="pref_pretend_local_name">伪装成本地存储</string>
    <string name="pref_pretend_local_desc">将 rclone 远程存储作为本地存储呈现给存储访问框架。这将强制与只允许选择本地文件的应用兼容。</string>
    <string name="pref_local_storage_access_name">允许本地存储访问</string>
    <string name="pref_local_storage_access_desc">允许包装远程存储（如 <tt>crypt</tt>）访问 <tt>/sdcard</tt> 下的本地存储。</string>
    <string name="pref_dialogs_at_bottom_name">在底部显示对话框</string>
    <string name="pref_dialogs_at_bottom_desc">使单手操作更容易，并防止对话框按钮移动。</string>
    <string name="pref_require_auth_name">需要身份验证</string>
    <string name="pref_require_auth_desc">需要生物识别解锁或屏幕锁定 PIN/密码才能查看和更改 RSAF 设置。</string>
    <string name="pref_inactivity_timeout_name">非活动超时</string>
    <plurals name="pref_inactivity_timeout_desc">
        <item quantity="one">离开应用 %d 秒后锁定。</item>
        <item quantity="other">离开应用 %d 秒后锁定。</item>
    </plurals>
    <string name="pref_lock_now_name">立即锁定</string>
    <string name="pref_lock_now_desc">立即锁定应用，而不是等待非活动超时。</string>
    <string name="pref_allow_backup_name">允许 Android 备份</string>
    <string name="pref_allow_backup_desc">如果 Android 声称传输是端到端加密的，或者正在直接传输到另一台设备，则允许备份应用数据。RSAF 无法知道这些条件是否真的成立。</string>
    <string name="pref_version_name">版本</string>
    <string name="pref_verbose_rclone_logs_name">详细的 rclone 日志</string>
    <string name="pref_verbose_rclone_logs_desc">警告：详细日志可能包含敏感信息，如身份验证令牌。</string>
    <string name="pref_save_logs_name">保存日志</string>
    <string name="pref_save_logs_desc">将 logcat 日志保存到文件。请注意，日志可能包含已访问的远程文件的名称。</string>
    <string name="pref_add_internal_cache_remote_name">添加 rclone 内部缓存远程存储</string>
    <string name="pref_add_internal_cache_remote_desc">添加一个新的指向 rclone 内部缓存目录的 <tt>alias</tt> 远程存储。这对于排查 VFS 问题可能很有用。</string>

    <!-- Remote preferences -->
    <string name="pref_edit_remote_open_name">打开远程存储</string>
    <string name="pref_edit_remote_open_desc">在系统文件管理器中打开此远程存储。</string>
    <string name="pref_edit_remote_configure_name">配置远程存储</string>
    <string name="pref_edit_remote_configure_desc">重新运行 rclone 配置向导。</string>
    <string name="pref_edit_remote_rename_name">重命名远程存储</string>
    <string name="pref_edit_remote_rename_desc">更改此远程存储的名称。如果其他远程存储依赖于此存储，则需要手动更新为新名称。</string>
    <string name="pref_edit_remote_duplicate_name">复制远程存储</string>
    <string name="pref_edit_remote_duplicate_desc">创建具有相同配置的此远程存储的副本。</string>
    <string name="pref_edit_remote_delete_name">删除远程存储</string>
    <string name="pref_edit_remote_delete_desc">从配置中删除此远程存储。</string>
    <string name="pref_edit_remote_allow_external_access_name">允许外部应用访问</string>
    <string name="pref_edit_remote_allow_external_access_desc">允许外部应用通过系统文件管理器访问此远程存储。如果此远程存储只是另一个远程存储的后端，则不需要访问权限。</string>
    <string name="pref_edit_remote_allow_locked_access_name">允许在锁定时访问</string>
    <string name="pref_edit_remote_allow_locked_access_desc_on">当 RSAF 被锁定时，文件仍然可供已获访问权限的外部应用使用。</string>
    <string name="pref_edit_remote_allow_locked_access_desc_off">当 RSAF 被锁定时，文件对外部应用隐藏，新的文件操作被阻止。与已打开文件的持续操作不受影响。</string>
    <string name="pref_edit_remote_dynamic_shortcut_name">在启动器快捷方式中显示</string>
    <string name="pref_edit_remote_dynamic_shortcut_desc">长按 RSAF 启动器图标时，将此远程存储包含在快捷方式列表中。</string>
    <string name="pref_edit_remote_thumbnails_name">启用缩略图</string>
    <string name="pref_edit_remote_thumbnails_desc">允许显示图像、视频和音乐（专辑封面）的缩略图。浏览文件时可能会产生额外的网络流量。</string>
    <string name="pref_edit_remote_report_usage_name">报告文件系统使用情况</string>
    <string name="pref_edit_remote_report_usage_desc_loading">(正在检查是否支持报告文件系统使用情况…)</string>
    <string name="pref_edit_remote_report_usage_desc_supported">向客户端应用报告可用空间和总空间。对于某些远程存储类型，当客户端应用获取远程存储列表时，这可能会显著减慢它们的速度。</string>
    <string name="pref_edit_remote_report_usage_desc_unsupported">此远程存储类型不支持报告其可用空间和总空间。</string>
    <string name="pref_edit_remote_vfs_options_name">自定义 VFS 选项</string>
    <string name="pref_edit_remote_vfs_options_desc">设置 <tt>rclone mount</tt> 支持的自定义 rclone VFS 选项。</string>

