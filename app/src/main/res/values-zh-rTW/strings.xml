    <!-- Main preferences -->
    <string name="pref_inhibit_battery_opt_name">停用電池最佳化</string>
    <string name="pref_inhibit_battery_opt_desc">需要在背景上傳檔案。</string>
    <string name="pref_allow_notifications_desc">需要在背景上傳檔案時顯示通知。</string>
    <string name="pref_add_remote_name">新增遠端儲存</string>
    <string name="pref_add_remote_desc">新增一個新的 rclone 遠端儲存設定。</string>
    <string name="pref_import_configuration_name">匯入設定</string>
    <string name="pref_import_configuration_desc">匯入現有的 rclone 設定檔。</string>
    <string name="pref_export_configuration_name">匯出設定</string>
    <string name="pref_export_configuration_desc">將目前的 rclone 設定匯出至檔案。</string>
    <string name="pref_add_file_extension_name">新增檔案副檔名</string>
    <string name="pref_add_file_extension_desc">建立新檔案時，自動加上對應檔案類型的副檔名。</string>
    <string name="pref_pretend_local_name">偽裝成本機儲存</string>
    <string name="pref_pretend_local_desc">將 rclone 遠端儲存以本機儲存的形式呈現給儲存空間存取架構。這會強制與僅允許選取本機檔案的應用程式相容。</string>
    <string name="pref_local_storage_access_name">允許本機儲存存取</string>
    <string name="pref_local_storage_access_desc">允許包裝遠端儲存（例如 <tt>crypt</tt>）存取 <tt>/sdcard</tt> 下的本機儲存空間。</string>
    <string name="pref_require_auth_name">需要驗證</string>
    <string name="pref_require_auth_desc">需要生物辨識解鎖或螢幕鎖定 PIN/密碼才能檢視及變更 RSAF 設定。</string>
    <string name="pref_inactivity_timeout_name">閒置逾時</string>
    <plurals name="pref_inactivity_timeout_desc">
        <item quantity="other">離開應用程式 %d 秒後鎖定。</item>
    </plurals>
    <string name="pref_lock_now_name">立即鎖定</string>
    <string name="pref_lock_now_desc">立即鎖定應用程式，而不是等待閒置逾時。</string>
    <string name="pref_allow_backup_name">允許 Android 備份</string>
    <string name="pref_allow_backup_desc">如果 Android 聲稱傳輸是端對端加密的，或正在直接傳輸到另一台裝置，則允許備份應用程式資料。RSAF 無法確認這些條件是否真的成立。</string>
    <string name="pref_version_name">版本</string>
    <string name="pref_verbose_rclone_logs_name">詳細的 rclone 紀錄</string>
    <string name="pref_verbose_rclone_logs_desc">警告：詳細紀錄可能包含敏感資訊，例如驗證憑證。</string>
    <string name="pref_save_logs_name">儲存紀錄</string>
    <string name="pref_save_logs_desc">將 logcat 紀錄儲存至檔案。請注意，紀錄可能包含已存取的遠端檔案名稱。</string>
    <string name="pref_add_internal_cache_remote_name">新增 rclone 內部快取遠端儲存</string>
    <string name="pref_add_internal_cache_remote_desc">新增一個指向 rclone 內部快取目錄的 <tt>alias</tt> 遠端儲存。這對於排查 VFS 問題可能很有用。</string>

    <!-- Remote preferences -->
    <string name="pref_edit_remote_open_name">開啟遠端儲存</string>
    <string name="pref_edit_remote_open_desc">在系統檔案管理器中開啟此遠端儲存。</string>
    <string name="pref_edit_remote_configure_name">設定遠端儲存</string>
    <string name="pref_edit_remote_configure_desc">重新執行 rclone 設定精靈。</string>
    <string name="pref_edit_remote_rename_name">重新命名遠端儲存</string>
    <string name="pref_edit_remote_rename_desc">變更此遠端儲存的名稱。如果其他遠端儲存依賴此儲存，則需要手動更新為新名稱。</string>
    <string name="pref_edit_remote_duplicate_name">複製遠端儲存</string>
    <string name="pref_edit_remote_duplicate_desc">建立具有相同設定的此遠端儲存的副本。</string>
    <string name="pref_edit_remote_delete_name">刪除遠端儲存</string>
    <string name="pref_edit_remote_delete_desc">從設定中移除此遠端儲存。</string>
    <string name="pref_edit_remote_allow_external_access_name">允許外部應用程式存取</string>
    <string name="pref_edit_remote_allow_external_access_desc">允許外部應用程式透過系統檔案管理器存取此遠端儲存。如果此遠端儲存只是另一個遠端儲存的後端，則不需要存取權限。</string>
    <string name="pref_edit_remote_allow_locked_access_name">允許鎖定時存取</string>
    <string name="pref_edit_remote_allow_locked_access_desc_on">當 RSAF 被鎖定時，檔案仍可供已取得存取權限的外部應用程式使用。</string>
    <string name="pref_edit_remote_allow_locked_access_desc_off">當 RSAF 被鎖定時，檔案會對外部應用程式隱藏，新的檔案操作會被封鎖。對已開啟檔案的持續操作不受影響。</string>
    <string name="pref_edit_remote_dynamic_shortcut_name">顯示於啟動器捷徑中</string>
    <string name="pref_edit_remote_dynamic_shortcut_desc">長按 RSAF 啟動器圖示時，將此遠端儲存包含在捷徑清單中。</string>
    <string name="pref_edit_remote_thumbnails_name">啟用縮圖</string>
    <string name="pref_edit_remote_thumbnails_desc">允許顯示影像、影片和音樂（專輯封面）的縮圖。瀏覽檔案時可能會產生額外的網路流量。</string>
    <string name="pref_edit_remote_report_usage_name">回報檔案系統使用量</string>
    <string name="pref_edit_remote_report_usage_desc_loading">（正在檢查是否支援回報檔案系統使用量…）</string>
    <string name="pref_edit_remote_report_usage_desc_supported">向用戶端應用程式回報可用空間及總空間。對於某些遠端儲存類型，當用戶端應用程式取得遠端儲存清單時，這可能會明顯拖慢速度。</string>
    <string name="pref_edit_remote_report_usage_desc_unsupported">此遠端儲存類型不支援回報其可用空間及總空間。</string>
    <string name="pref_edit_remote_vfs_options_name">自訂 VFS 選項</string>
    <string name="pref_edit_remote_vfs_options_desc">設定 <tt>rclone mount</tt> 支援的自訂 rclone VFS 選項。</string>

